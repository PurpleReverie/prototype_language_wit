\- shared/schema.wit — vocabulary definitions, available to every file
   that references this one. -\

#cite: ||author, title, year, publisher|| ! ::author:: (::year::). _::title::_. ::publisher::. !

#chapter ||number, title||
@chapterheader
::number:: — ::title::
chapterheader@
...
chapter#

#epigraph ||source||
@epigraphbody
...
— ::source::
epigraphbody@
epigraph#
