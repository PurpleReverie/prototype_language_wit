{
  "comments": {
    "lineComment": "~",
    "blockComment": ["~~", "~~/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "<%", "close": "%>" },
    { "open": "~~", "close": "~~/" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["_", "_"],
    ["*", "*"]
  ],
  "indentationRules": {},
  "wordPattern": "[A-Za-z0-9_-]+"
}
