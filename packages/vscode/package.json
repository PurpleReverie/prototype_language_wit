{
  "name": "wit-vscode",
  "displayName": "Wit Language",
  "description": "Language support for Wit (.wit) files: syntax highlighting and language server.",
  "version": "0.1.0",
  "private": true,
  "publisher": "wit",
  "type": "module",
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./client/dist/extension.js",
  "activationEvents": [
    "onLanguage:wit"
  ],
  "contributes": {
    "languages": [
      {
        "id": "wit",
        "aliases": [
          "Wit",
          "wit"
        ],
        "extensions": [
          ".wit"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wit",
        "scopeName": "source.wit",
        "path": "./syntaxes/wit.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "typecheck": "tsc --build --noEmit",
    "bundle:client": "esbuild client/extension.ts --bundle --platform=node --target=node20 --external:vscode --format=cjs --outfile=client/dist/extension.js",
    "bundle:server": "esbuild server/server.ts --bundle --platform=node --target=node20 --external:vscode --format=cjs --outfile=server/dist/server.js",
    "bundle": "pnpm run bundle:client && pnpm run bundle:server",
    "build": "pnpm run bundle",
    "package": "vsce package --no-dependencies --out wit-vscode.vsix",
    "install:local": "command -v code >/dev/null || { echo 'VS Code CLI (code) not on PATH. In VS Code: Cmd-Shift-P → Shell Command: Install code command in PATH.'; exit 1; } && pnpm run build && pnpm exec vsce package --no-dependencies --out wit-vscode.vsix && code --install-extension wit-vscode.vsix && rm -f wit-vscode.vsix"
  },
  "devDependencies": {
    "@wit/parser": "workspace:*",
    "@wit/runtime": "workspace:*",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.4",
    "vsce": "^2.15.0",
    "vscode-languageclient": "^10.0.0",
    "vscode-languageserver": "^10.0.0",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
