{
  "name": "@witlang/runtime",
  "version": "0.2.0",
  "description": "Resolver + expander runtime for the Wit markup language",
  "keywords": [
    "wit",
    "markup",
    "runtime",
    "expander",
    "resolver"
  ],
  "license": "MIT",
  "author": "Tauraj Greig",
  "repository": {
    "type": "git",
    "url": "https://github.com/PurpleReverie/prototype_language_wit.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/PurpleReverie/prototype_language_wit#readme",
  "bugs": "https://github.com/PurpleReverie/prototype_language_wit/issues",
  "type": "module",
  "main": "./dist/index.js",
