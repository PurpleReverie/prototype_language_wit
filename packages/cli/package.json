{
  "name": "@witlang/cli",
  "version": "0.2.0",
  "description": "Command-line tool for the Wit markup language — parse, check, build, tour",
  "keywords": [
    "wit",
    "markup",
    "cli",
    "language"
  ],
  "license": "MIT",
  "author": "Tauraj Greig",
  "repository": {
    "type": "git",
    "url": "https://github.com/PurpleReverie/prototype_language_wit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/PurpleReverie/prototype_language_wit#readme",
  "bugs": "https://github.com/PurpleReverie/prototype_language_wit/issues",
  "type": "module",
  "main": "./dist/bin.js",
  "bin": {
    "wit": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@witlang/parser": "workspace:*",
    "@witlang/runtime": "workspace:*",
    "@witlang/render-html": "workspace:*",
    "@witlang/render-markdown": "workspace:*"
  }
}
