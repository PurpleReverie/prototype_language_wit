#adr: {
  number - 0014
  title - Adopt Wit for project documentation
  status - accepted
  date - 2026-03-14
  authors - Mara Finch and Aldous Vane
}

#options: [
  { name - Markdown,
    pros - Familiar and ubiquitous tooling,
    cons - Weak structure — breaks on tables and citations }
  { name - AsciiDoc,
    pros - Powerful and well-structured,
    cons - Heavyweight syntax — smaller ecosystem }
  { name - reStructuredText,
    pros - Strong directives in the Python ecosystem,
    cons - Awkward syntax — sparse tooling outside Sphinx }
  { name - Wit,
    pros - Prose-first and data-driven with a custom-renderer hook,
    cons - New language with a smaller community }
]

