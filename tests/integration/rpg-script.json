                        "body": [
                          {
                            "children": [
                              {
                                "kind": "text",
                                "value": "He knows it's here. He knows the name Baggins."
                              }
                            ],
                            "kind": "paragraph"
                          }
                        ],
                        "closeStyle": "named",
                        "inline": false,
                        "kind": "nodeUse",
                        "name": "say",
                        "params": [
