                                "paramsSource": "pipes"
                              },
                              {
                                "body": [
                                  {
                                    "children": [
                                      {
                                        "kind": "text",
                                        "value": "You see further than you let on. Yes — and we have less\ntime than I had hoped."
                                      }
                                    ],
                                    "kind": "paragraph"
                                  }
                                ],
                                "closeStyle": "named",
                                "inline": false,
                                "kind": "nodeUse",
                                "name": "say",
                                "params": [
                                  {
