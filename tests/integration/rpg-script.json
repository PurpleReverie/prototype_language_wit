                            "value": "Frodo"
                          },
                          {
                            "name": "mood",
                            "value": "panicked"
                          }
                        ],
                        "paramsSource": "pipes"
                      },
                      {
                        "body": [
                          {
                            "children": [
                              {
                                "kind": "text",
                                "value": "He does. You cannot stay — not for another night."
                              }
                            ],
                            "kind": "paragraph"
                          }
                        ],
                        "closeStyle": "named",
                        "inline": false,
                        "kind": "nodeUse",
